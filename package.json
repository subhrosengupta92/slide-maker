{
  "name": "slide-maker",
  "version": "0.1.0",
  "description": "Agentic PPTX deck generator with high-design templates.",
  "type": "module",
  "bin": {
    "slide-maker": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "generate": "tsx src/cli.ts build",
    "test": "vitest run"
  },
  "keywords": [
    "pptx",
    "slides",
    "ai",
    "agentic",
    "presentation"
  ],
  "author": "Mosaic",
