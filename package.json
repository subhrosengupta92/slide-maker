  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "openai": "^6.25.0",
    "pptxgenjs": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
